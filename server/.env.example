# Скопируй в .env и заполни своими значениями
NODE_ENV=development
PORT=5000

# Строка подключения MongoDB (Atlas или локальная)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# Секрет для подписи JWT (любая длинная случайная строка, минимум 16 символов)
JWT_SECRET=change_me_to_a_long_random_string
# Время жизни access-токена (минуты) и refresh-токена (дни)
JWT_ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=7

# Базовый URL бэкенда (для генерации коротких ссылок)
APP_BASE_URL=http://localhost:5000
# URL фронтенда (для CORS)
CLIENT_URL=http://localhost:5173

# Опционально: переопределить DNS-серверы (через запятую).
# Раскомментируй, если системный DNS не резолвит SRV-записи MongoDB Atlas.
# DNS_SERVERS=8.8.8.8,1.1.1.1
