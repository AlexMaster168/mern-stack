{
  "name": "mern-stack",
  "version": "2.0.0",
  "description": "Платформа: сокращатель ссылок + LMS (модернизированный MERN-стек)",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm --filter @mern-stack/server dev\" \"pnpm --filter @mern-stack/client dev\"",
    "dev:server": "pnpm --filter @mern-stack/server dev",
    "dev:client": "pnpm --filter @mern-stack/client dev",
    "build": "pnpm --filter @mern-stack/server build && pnpm --filter @mern-stack/client build",
    "start": "pnpm --filter @mern-stack/server start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @mern-stack/server test",
    "seed": "pnpm --filter @mern-stack/server seed"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mern",
    "typescript",
    "url-shortener",
    "lms"
  ],
  "author": "Alex master",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^10.0.0"
  }
}
